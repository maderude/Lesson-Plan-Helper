# ==============================================================================
# Lesson Plan Helper — Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in your actual values.
# Never commit the real `.env` file to version control.
# ==============================================================================

# OpenAI API key (required for LLM-powered agents)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Override the default model used by agents
# OPENAI_MODEL=gpt-4o

# Optional: ChromaDB persistence directory (defaults to in-memory if unset)
# CHROMA_PERSIST_DIR=./chroma_data

# Optional: FastAPI server configuration
# API_HOST=0.0.0.0
# API_PORT=8000
